  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "D28V_Ar6T6iv"
   },
   "outputs": [],
   "source": [
    "TOP_K = 10\n",
    "\n",
    "# Select the highest-scoring edges from the GraphEXT-style edge mask\n",
    "top_k_edges_graphext = min(TOP_K, edge_scores_graphext.numel())\n",
    "\n",
    "top_edge_values_graphext, top_edge_indices_graphext = torch.topk(\n",
    "    edge_scores_graphext.detach().cpu(),\n",
    "    k=top_k_edges_graphext,\n",
    ")\n",
    "\n",
    "top_graphext_edges = []\n",
    "\n",
    "for rank, edge_idx in enumerate(top_edge_indices_graphext, start=1):\n",
    "    edge_idx = int(edge_idx.item())\n",
    "\n",
    "    # Retrieve local source and target nodes\n",
    "    source_local = int(sub_edge_index[0, edge_idx].item())\n",
    "    target_local = int(sub_edge_index[1, edge_idx].item())\n",
    "\n",
    "    # Map local node indices back to original graph IDs\n",
    "    source_original = int(subset[source_local].item())\n",
    "    target_original = int(subset[target_local].item())\n",
    "\n",
    "    edge_score = float(top_edge_values_graphext[rank - 1].item())\n",
    "\n",
    "    top_graphext_edges.append(\n",
