   "source": [
    "# 12.  GraphEXT\n",
    "\n",
    "This explainer learns a soft mask over the edges of the local subgraph.  \n",
    "Unlike node-based explainers, this method assigns importance directly to edges, without using feature masks or node feature attributions.\n",
    "\n",
    "The objective is designed to preserve the fraud prediction of the target node while encouraging the learned edge mask to remain compact and close to a binary selection.  \n",
    "In this way, the explainer tries to identify a small set of relevant edges that are sufficient to maintain the target fraud prediction.\n",
    "\n",
    "The trained GCN copy compatible with explicit edge weights is used for this step."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "w_eP6aIvTQze"
   },
   "outputs": [],
   "source": [
    "class GraphEXTExplainer(nn.Module):\n",
    "    \"\"\"GraphEXT-style explainer that learns a soft edge mask.\"\"\"\n",
    "\n",
    "    def __init__(self, num_edges):\n",
    "        super().__init__()\n",
    "        self.edge_logits = nn.Parameter(torch.randn(num_edges) * 0.1)\n",
    "\n",
    "    def forward(self):\n",
    "        return torch.sigmoid(self.edge_logits)\n",
    "\n",
    "\n",
    "def run_graphext_explainer(\n",
    "    model,\n",
    "    sub_x,\n",
    "    sub_edge_index,\n",
    "    target_sub_idx,\n",
    "    target_class=1,\n",
    "    epochs=300,\n",
    "    lr=0.01,\n",
    "    lambda_sparsity=0.05,\n",
    "    lambda_entropy=0.02,\n",
    "    device=device,\n",
    "    verbose=True,\n",
    "):\n",
    "    \"\"\"Learn an edge-level structural mask for the target prediction.\"\"\"\n",
    "    model.eval()\n",
    "\n",
    "    sub_x = sub_x.to(device)\n",
    "    sub_edge_index = sub_edge_index.to(device)\n",
    "\n",
    "    num_edges = sub_edge_index.size(1)\n",
    "\n",
    "    explainer = GraphEXTExplainer(num_edges).to(device)\n",
    "    optimizer_graphext = torch.optim.Adam(explainer.parameters(), lr=lr)\n",
    "\n",
    "    graphext_history = []\n",
    "\n",
    "    # Baseline prediction before learning the edge mask\n",
    "    with torch.no_grad():\n",
    "        base_out = model(sub_x, sub_edge_index)\n",
    "        base_probs = base_out.exp()[target_sub_idx]\n",
    "        base_prob = float(base_probs[target_class].item())\n",
    "        base_pred = int(base_probs.argmax().item())\n",
    "\n",
    "    for epoch in range(1, epochs + 1):\n",
    "        optimizer_graphext.zero_grad()\n",
    "\n",
    "        edge_mask = explainer()\n",
    "\n",
    "        # Forward pass using the learned soft edge mask\n",
    "        out_masked = model(\n",
    "            sub_x,\n",
    "            sub_edge_index,\n",
    "            edge_weight=edge_mask,\n",
    "        )\n",
    "\n",
    "        prob_target = out_masked.exp()[target_sub_idx, target_class]\n",
    "\n",
    "        # Preserve the target fraud prediction\n",
    "        loss_prediction = -torch.log(prob_target + 1e-8)\n",
    "\n",
    "        # Keep the explanation compact\n",
    "        loss_sparsity = edge_mask.mean()\n",
    "\n",
    "        # Encourage near-binary edge scores\n",
    "        loss_entropy = -(\n",
    "            edge_mask * torch.log(edge_mask + 1e-8)\n",
    "            + (1.0 - edge_mask) * torch.log(1.0 - edge_mask + 1e-8)\n",
    "        ).mean()\n",
    "\n",
    "        loss = (\n",
    "            loss_prediction\n",
    "            + lambda_sparsity * loss_sparsity\n",
    "            + lambda_entropy * loss_entropy\n",
    "        )\n",
    "\n",
    "        loss.backward()\n",
    "        optimizer_graphext.step()\n",
    "\n",
    "        graphext_history.append(\n",
    "            {\n",
    "                \"epoch\": epoch,\n",
    "                \"loss\": float(loss.item()),\n",
    "                \"p_fraud\": float(prob_target.item()),\n",
    "                \"mask_mean\": float(edge_mask.mean().item()),\n",
    "            }\n",
    "        )\n",
    "\n",
    "        if verbose and (epoch == 1 or epoch % 50 == 0):\n",
    "            print(\n",
    "                f\"Epoch {epoch:03d} | \"\n",
    "                f\"Loss: {loss.item():.4f} | \"\n",
    "                f\"P(fraud): {prob_target.item():.4f} | \"\n",
    "                f\"Mask mean: {edge_mask.mean().item():.4f}\"\n",
    "            )\n",
    "\n",
    "    with torch.no_grad():\n",
    "        final_edge_mask = explainer().detach().cpu()\n",
    "\n",
    "        # Normalize edge scores to [0, 1]\n",
    "        final_edge_mask = (\n",
    "            (final_edge_mask - final_edge_mask.min())\n",
    "            / (final_edge_mask.max() - final_edge_mask.min() + 1e-8)\n",
    "        )\n",
    "\n",
    "    graphext_history_df = pd.DataFrame(graphext_history)\n",
    "\n",
    "    return final_edge_mask, base_prob, base_pred, graphext_history_df\n",
    "\n",
    "\n",
    "edge_scores_graphext, graphext_base_prob, graphext_base_pred, graphext_history_df = run_graphext_explainer(\n",
    "    model=model_ig,\n",
    "    sub_x=sub_x,\n",
    "    sub_edge_index=sub_edge_index,\n",
    "    target_sub_idx=target_sub_idx,\n",
    "    target_class=1,\n",
    "    epochs=300,\n",
    "    lr=0.01,\n",
    "    lambda_sparsity=0.05,\n",
    "    lambda_entropy=0.02,\n",
    "    device=device,\n",
    "    verbose=True,\n",
    ")\n",
    "\n",
    "graphext_summary = pd.DataFrame(\n",
    "    {\n",
    "        \"Property\": [\n",
    "            \"Explainer\",\n",
    "            \"Explanation type\",\n",
    "            \"Mask type\",\n",
    "            \"Target original node ID\",\n",
    "            \"True label\",\n",
    "            \"Baseline predicted class\",\n",
    "            \"Baseline P(fraud)\",\n",
    "            \"Edge mask shape\",\n",
    "            \"Edge mask minimum\",\n",
    "            \"Edge mask maximum\",\n",
    "            \"Edge mask mean\",\n",
    "            \"Non-zero importance edges\",\n",
    "        ],\n",
    "        \"Value\": [\n",
    "            \"GraphEXT-style explainer\",\n",
    "            \"Edge-level structural explanation\",\n",
    "            \"Object-level edge importance\",\n",
    "            target_node_id,\n",
    "            int(graph_data.y[target_node_id].item()),\n",
    "            graphext_base_pred,\n",
    "            f\"{graphext_base_prob:.6f}\",\n",
    "            tuple(edge_scores_graphext.shape),\n",
    "            f\"{edge_scores_graphext.min().item():.6f}\",\n",
    "            f\"{edge_scores_graphext.max().item():.6f}\",\n",
    "            f\"{edge_scores_graphext.mean().item():.6f}\",\n",
    "            int((edge_scores_graphext > 0).sum().item()),\n",
    "        ],\n",
    "    }\n",
    ")\n",
    "\n",
    "display(graphext_summary)"
   ]
  },
