   "source": [
    "TOP_K = 10\n",
    "\n",
    "# Select the highest-scoring edges from the ORExplainer-style edge mask\n",
    "top_k_edges_or = min(TOP_K, edge_scores_or.numel())\n",
    "\n",
    "top_edge_values_or, top_edge_indices_or = torch.topk(\n",
    "    edge_scores_or.detach().cpu(),\n",
