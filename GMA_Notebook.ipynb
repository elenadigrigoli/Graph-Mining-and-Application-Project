   "source": [
    "# 13. ORExplainer\n",
    "\n",
    "An ORExplainer-style structural explainer is implemented as an additional edge-based explanation method.\n",
    "\n",
    "The explainer learns a soft mask over the directed edges of the local subgraph.  \n",
    "The explanation is therefore structural: no node feature mask is learned and no feature-level attribution is produced.\n",
    "\n",
    "The objective preserves the fraud prediction of the target node while penalizing large explanations and encouraging the learned edge mask to become close to binary values.  \n",
    "Compared with the previous GraphEXT-style explainer, this implementation uses a slightly stronger size and entropy regularization, making it more focused on selecting a compact set of relevant edges.\n",
    "\n",
    "The trained GCN copy compatible with explicit edge weights is used for this step."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "Dzb4JPdpVQ7C"
   },
   "outputs": [],
   "source": [
    "class ORExplainer(nn.Module):\n",
    "    \"\"\"ORExplainer-style explainer that learns a soft edge mask.\"\"\"\n",
    "\n",
    "    def __init__(self, num_edges):\n",
    "        super().__init__()\n",
    "        self.edge_logits = nn.Parameter(torch.randn(num_edges) * 0.1)\n",
    "\n",
    "    def forward(self):\n",
    "        return torch.sigmoid(self.edge_logits)\n",
    "\n",
    "\n",
    "def run_orexplainer(\n",
    "    model,\n",
    "    sub_x,\n",
    "    sub_edge_index,\n",
    "    target_sub_idx,\n",
    "    target_class=1,\n",
    "    epochs=300,\n",
    "    lr=0.01,\n",
    "    lambda_size=0.08,\n",
    "    lambda_entropy=0.03,\n",
    "    device=device,\n",
    "    verbose=True,\n",
    "):\n",
    "    \"\"\"Learn an edge-level mask using an ORExplainer-style objective.\"\"\"\n",
    "    model.eval()\n",
    "\n",
    "    sub_x = sub_x.to(device)\n",
    "    sub_edge_index = sub_edge_index.to(device)\n",
    "\n",
    "    num_edges = sub_edge_index.size(1)\n",
    "\n",
    "    explainer = ORExplainer(num_edges).to(device)\n",
    "    optimizer_or = torch.optim.Adam(explainer.parameters(), lr=lr)\n",
    "\n",
    "    or_history = []\n",
    "\n",
    "    # Baseline prediction before learning the edge mask\n",
    "    with torch.no_grad():\n",
    "        base_out = model(sub_x, sub_edge_index)\n",
    "        base_probs = base_out.exp()[target_sub_idx]\n",
    "        base_prob = float(base_probs[target_class].item())\n",
    "        base_pred = int(base_probs.argmax().item())\n",
    "\n",
    "    for epoch in range(1, epochs + 1):\n",
    "        optimizer_or.zero_grad()\n",
    "\n",
    "        edge_mask = explainer()\n",
    "\n",
    "        # Forward pass using the learned soft edge mask\n",
    "        out_masked = model(\n",
    "            sub_x,\n",
    "            sub_edge_index,\n",
    "            edge_weight=edge_mask,\n",
    "        )\n",
    "\n",
    "        prob_target = out_masked.exp()[target_sub_idx, target_class]\n",
    "\n",
    "        # Preserve the target fraud prediction\n",
    "        loss_prediction = -torch.log(prob_target + 1e-8)\n",
    "\n",
    "        # Penalize large explanations\n",
    "        loss_size = edge_mask.mean()\n",
    "\n",
    "        # Encourage near-binary edge scores\n",
    "        loss_entropy = -(\n",
    "            edge_mask * torch.log(edge_mask + 1e-8)\n",
    "            + (1.0 - edge_mask) * torch.log(1.0 - edge_mask + 1e-8)\n",
    "        ).mean()\n",
    "\n",
    "        loss = (\n",
    "            loss_prediction\n",
    "            + lambda_size * loss_size\n",
    "            + lambda_entropy * loss_entropy\n",
    "        )\n",
    "\n",
    "        loss.backward()\n",
    "        optimizer_or.step()\n",
    "\n",
    "        or_history.append(\n",
    "            {\n",
    "                \"epoch\": epoch,\n",
    "                \"loss\": float(loss.item()),\n",
    "                \"p_fraud\": float(prob_target.item()),\n",
    "                \"mask_mean\": float(edge_mask.mean().item()),\n",
    "            }\n",
    "        )\n",
    "\n",
    "        if verbose and (epoch == 1 or epoch % 50 == 0):\n",
    "            print(\n",
    "                f\"Epoch {epoch:03d} | \"\n",
    "                f\"Loss: {loss.item():.4f} | \"\n",
    "                f\"P(fraud): {prob_target.item():.4f} | \"\n",
    "                f\"Mask mean: {edge_mask.mean().item():.4f}\"\n",
    "            )\n",
    "\n",
    "    with torch.no_grad():\n",
    "        final_edge_mask = explainer().detach().cpu()\n",
    "\n",
    "        # Normalize edge scores to [0, 1]\n",
    "        final_edge_mask = (\n",
    "            (final_edge_mask - final_edge_mask.min())\n",
    "            / (final_edge_mask.max() - final_edge_mask.min() + 1e-8)\n",
    "        )\n",
    "\n",
    "    or_history_df = pd.DataFrame(or_history)\n",
    "\n",
    "    return final_edge_mask, base_prob, base_pred, or_history_df\n",
    "\n",
    "\n",
    "edge_scores_or, or_base_prob, or_base_pred, or_history_df = run_orexplainer(\n",
    "    model=model_ig,\n",
    "    sub_x=sub_x,\n",
    "    sub_edge_index=sub_edge_index,\n",
    "    target_sub_idx=target_sub_idx,\n",
    "    target_class=1,\n",
    "    epochs=300,\n",
    "    lr=0.01,\n",
    "    lambda_size=0.08,\n",
    "    lambda_entropy=0.03,\n",
    "    device=device,\n",
    "    verbose=True,\n",
    ")\n",
    "\n",
    "or_summary = pd.DataFrame(\n",
    "    {\n",
    "        \"Property\": [\n",
    "            \"Explainer\",\n",
    "            \"Explanation type\",\n",
    "            \"Mask type\",\n",
    "            \"Target original node ID\",\n",
    "            \"True label\",\n",
    "            \"Baseline predicted class\",\n",
    "            \"Baseline P(fraud)\",\n",
    "            \"Edge mask shape\",\n",
    "            \"Edge mask minimum\",\n",
    "            \"Edge mask maximum\",\n",
    "            \"Edge mask mean\",\n",
    "            \"Non-zero importance edges\",\n",
    "        ],\n",
    "        \"Value\": [\n",
    "            \"ORExplainer-style explainer\",\n",
    "            \"Edge-level structural explanation\",\n",
    "            \"Object-level edge importance\",\n",
    "            target_node_id,\n",
    "            int(graph_data.y[target_node_id].item()),\n",
    "            or_base_pred,\n",
    "            f\"{or_base_prob:.6f}\",\n",
    "            tuple(edge_scores_or.shape),\n",
    "            f\"{edge_scores_or.min().item():.6f}\",\n",
    "            f\"{edge_scores_or.max().item():.6f}\",\n",
    "            f\"{edge_scores_or.mean().item():.6f}\",\n",
    "            int((edge_scores_or > 0).sum().item()),\n",
    "        ],\n",
    "    }\n",
    ")\n",
    "\n",
    "display(or_summary)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "hbI1sCVIVbW2"
   },
   "source": [
    "\n",
    "\n",
    "During optimization, the loss decreases from `0.2153` to `0.1155`, showing that the explainer progressively improves its ability to preserve the target prediction while applying regularization to the edge mask.\n",
    "\n",
    "At the same time, the fraud probability increases from `0.8570` to `0.9439`.  \n",
    "This indicates that the masked subgraph learned by ORExplainer is sufficient to maintain a strong fraud prediction for the target node.\n",
    "\n",
    "The mask mean remains more controlled than in the GraphEXT-style explainer.  \n",
    "It starts around `0.5016`, increases during training, and stabilizes around `0.5691`.  \n",
    "This is consistent with the stronger size and entropy regularization used in ORExplainer, which encourages a more compact explanation.\n",
    "\n",
    "The final normalized edge mask has shape `(92,)`, assigning one importance score to each directed edge in the local subgraph.  \n",
    "The scores are normalized between `0` and `1`, with a final mean value of approximately `0.5842`.\n",
    "\n",
    "As with GraphEXT, almost all edges receive a non-zero importance value, with `91` non-zero edges out of `92`.  \n"
   ]
  },
