   },
   "source": [
    "# **Explainable Graph AI using DGraphFin Dataset with a Graph Convolutional Network**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "FB7o6xUTH-5X"
   },
   "source": [
    "## 1. Import Dataset"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "J4tjjsh3y68J"
   },
   "source": [
    "In this first step, the DGraphFin dataset is downloaded from KaggleHub and loaded into memory.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "RzTtF1AwKyg1",
    "outputId": "1ccef413-5e2a-4e12-8c36-072e79421fa1"
   },
   "outputs": [],
   "source": [
    "import os\n",
    "import kagglehub\n",
    "import numpy as np\n",
    "\n",
    "# Download the DGraphFin dataset from KaggleHub\n",
    "dataset_path = kagglehub.dataset_download(\"gahoiambuj/dgraphfin\")\n",
    "\n",
    "# Locate the .npz file in the downloaded directory\n",
    "npz_files = [file for file in os.listdir(dataset_path) if file.endswith(\".npz\")]\n",
    "\n",
    "if not npz_files:\n",
    "    raise FileNotFoundError(\"No .npz file was found in the downloaded dataset folder.\")\n",
    "\n",
    "dataset_file = npz_files[0]\n",
    "dataset_file_path = os.path.join(dataset_path, dataset_file)\n",
    "\n",
    "# Load the dataset\n",
    "data = np.load(dataset_file_path, allow_pickle=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "Bdtk7pm5zqE-"
   },
   "source": [
