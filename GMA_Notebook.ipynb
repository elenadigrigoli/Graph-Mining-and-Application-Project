   "source": [
    "### 13.2 Visualization\n",
    "The ORExplainer-style explainer ranks the most important edges according to the learned edge mask.\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "QyHJkK7-XByX"
   },
   "outputs": [],
   "source": [
    "TOP_K_PLOT_OR = min(10, edge_scores_or.numel())\n",
    "\n",
    "top_edge_values_or, top_edge_indices_or = torch.topk(\n",
    "    edge_scores_or.detach().cpu(),\n",
    "    k=TOP_K_PLOT_OR,\n",
    ")\n",
    "\n",
    "# Build a directed graph from the top ORExplainer edges\n",
    "G_or = nx.DiGraph()\n",
    "\n",
    "for rank, edge_idx in enumerate(top_edge_indices_or, start=1):\n",
    "    edge_idx = int(edge_idx.item())\n",
    "\n",
    "    # Retrieve local edge endpoints\n",
    "    source_local = int(sub_edge_index[0, edge_idx].item())\n",
    "    target_local = int(sub_edge_index[1, edge_idx].item())\n",
    "\n",
    "    # Map local indices back to original graph node IDs\n",
    "    source_original = int(subset[source_local].item())\n",
    "    target_original = int(subset[target_local].item())\n",
    "\n",
    "    edge_score = float(top_edge_values_or[rank - 1].item())\n",
    "\n",
    "    # Store node metadata for plotting\n",
    "    for original_id, local_idx in [\n",
    "        (source_original, source_local),\n",
    "        (target_original, target_local),\n",
    "    ]:\n",
    "        label_value = int(graph_data.y[original_id].item())\n",
    "\n",
    "        G_or.add_node(\n",
    "            original_id,\n",
    "            local_idx=local_idx,\n",
    "            label=label_value,\n",
    "            is_target=original_id == target_node_id,\n",
    "        )\n",
    "\n",
    "    G_or.add_edge(\n",
    "        source_original,\n",
    "        target_original,\n",
    "        weight=edge_score,\n",
    "        rank=rank,\n",
    "    )\n",
    "\n",
    "\n",
    "# Node color palette\n",
    "node_color_map = {\n",
    "    \"target\": \"#d62728\",\n",
    "    \"fraud\": \"#ff7f0e\",\n",
    "    \"legitimate\": \"#4c78a8\",\n",
    "    \"unknown\": \"#9e9e9e\",\n",
    "}\n",
    "\n",
    "node_colors_or = []\n",
    "node_sizes_or = []\n",
    "node_border_widths_or = []\n",
    "\n",
    "for node, attributes in G_or.nodes(data=True):\n",
    "    label_value = attributes[\"label\"]\n",
    "\n",
    "    if attributes[\"is_target\"]:\n",
    "        node_colors_or.append(node_color_map[\"target\"])\n",
    "        node_sizes_or.append(2400)\n",
    "        node_border_widths_or.append(3.2)\n",
    "    elif label_value == 1:\n",
    "        node_colors_or.append(node_color_map[\"fraud\"])\n",
    "        node_sizes_or.append(1450)\n",
    "        node_border_widths_or.append(1.6)\n",
    "    elif label_value == 0:\n",
    "        node_colors_or.append(node_color_map[\"legitimate\"])\n",
    "        node_sizes_or.append(1350)\n",
    "        node_border_widths_or.append(1.4)\n",
    "    else:\n",
    "        node_colors_or.append(node_color_map[\"unknown\"])\n",
    "        node_sizes_or.append(1300)\n",
    "        node_border_widths_or.append(1.2)\n",
    "\n",
    "\n",
    "# Scale edge widths according to ORExplainer scores\n",
    "edge_weights_or = np.array(\n",
    "    [G_or[u][v][\"weight\"] for u, v in G_or.edges()],\n",
    "    dtype=float,\n",
    ")\n",
    "\n",
    "edge_widths_or = 2.0 + 5.0 * (\n",
    "    (edge_weights_or - edge_weights_or.min())\n",
    "    / (edge_weights_or.max() - edge_weights_or.min() + 1e-8)\n",
    ")\n",
    "\n",
    "\n",
    "# Build a readable layout for target and contextual components\n",
    "components = list(nx.weakly_connected_components(G_or))\n",
    "components = sorted(\n",
    "    components,\n",
    "    key=lambda component: target_node_id not in component,\n",
    ")\n",
    "\n",
    "pos_or = {}\n",
    "\n",
    "for component_id, component_nodes in enumerate(components):\n",
    "    component_graph = G_or.subgraph(component_nodes).copy()\n",
    "\n",
    "    # Put the target-centered component on the right\n",
    "    if target_node_id in component_nodes:\n",
    "        center = np.array([2.4, 0.0])\n",
    "        scale = 1.3\n",
    "    else:\n",
    "        center = np.array([-1.7, 1.5 - component_id * 1.5])\n",
    "        scale = 0.9\n",
    "\n",
    "    component_pos = nx.spring_layout(\n",
    "        component_graph,\n",
    "        seed=SEED + component_id,\n",
    "        k=1.4,\n",
    "        iterations=300,\n",
    "        scale=scale,\n",
    "        center=center,\n",
    "    )\n",
    "\n",
    "    pos_or.update(component_pos)\n",
    "\n",
    "\n",
    "# Force target and incoming neighbors into a cleaner arrangement\n",
    "if target_node_id in pos_or:\n",
    "    pos_or[target_node_id] = np.array([3.3, 0.0])\n",
    "\n",
    "incoming_neighbors_or = [\n",
    "    source\n",
    "    for source, target in G_or.edges()\n",
    "    if target == target_node_id\n",
    "]\n",
    "\n",
    "if incoming_neighbors_or:\n",
    "    y_positions = np.linspace(2.6, -2.6, len(incoming_neighbors_or))\n",
    "    x_positions = np.array([\n",
    "        1.05 if i % 2 == 0 else 1.55\n",
    "        for i in range(len(incoming_neighbors_or))\n",
    "    ])\n",
    "\n",
    "    for node, x_value, y_value in zip(\n",
    "        incoming_neighbors_or,\n",
    "        x_positions,\n",
    "        y_positions,\n",
    "    ):\n",
    "        pos_or[node] = np.array([x_value, y_value])\n",
    "\n",
    "\n",
    "# Node labels outside the nodes\n",
    "node_labels_or = {}\n",
    "\n",
    "for node, attributes in G_or.nodes(data=True):\n",
    "    label_value = attributes[\"label\"]\n",
    "\n",
    "    if attributes[\"is_target\"]:\n",
    "        node_labels_or[node] = f\"TARGET\\n{node}\\nlabel={label_value}\"\n",
    "    else:\n",
    "        node_labels_or[node] = f\"{node}\\nlabel={label_value}\"\n",
    "\n",
    "label_pos_or = {}\n",
    "\n",
    "for node, coords in pos_or.items():\n",
    "    x, y = coords\n",
    "\n",
    "    if node == target_node_id:\n",
    "        label_pos_or[node] = (x + 0.38, y + 0.18)\n",
    "    else:\n",
    "        label_pos_or[node] = (x, y + 0.22)\n",
    "\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(15.5, 9))\n",
    "\n",
    "nx.draw_networkx_edges(\n",
    "    G_or,\n",
    "    pos_or,\n",
    "    ax=ax,\n",
    "    width=edge_widths_or,\n",
    "    edge_color=\"#5f5f5f\",\n",
    "    alpha=0.75,\n",
    "    arrows=True,\n",
    "    arrowstyle=\"-|>\",\n",
    "    arrowsize=26,\n",
    "    connectionstyle=\"arc3,rad=0.06\",\n",
    ")\n",
    "\n",
    "nx.draw_networkx_nodes(\n",
    "    G_or,\n",
    "    pos_or,\n",
    "    ax=ax,\n",
    "    node_color=node_colors_or,\n",
    "    node_size=node_sizes_or,\n",
    "    edgecolors=\"#1f1f1f\",\n",
    "    linewidths=node_border_widths_or,\n",
    "    alpha=0.96,\n",
    ")\n",
    "\n",
    "nx.draw_networkx_labels(\n",
    "    G_or,\n",
    "    label_pos_or,\n",
    "    labels=node_labels_or,\n",
    "    ax=ax,\n",
    "    font_size=8.8,\n",
    "    font_weight=\"bold\",\n",
    "    font_color=\"black\",\n",
    "    bbox={\n",
    "        \"boxstyle\": \"round,pad=0.25\",\n",
    "        \"facecolor\": \"white\",\n",
    "        \"edgecolor\": \"#d0d0d0\",\n",
    "        \"alpha\": 0.92,\n",
    "    },\n",
    ")\n",
    "\n",
    "\n",
    "# Place edge scores close to the source side to reduce overlap\n",
    "for label_idx, (u, v) in enumerate(G_or.edges()):\n",
    "    x1, y1 = pos_or[u]\n",
    "    x2, y2 = pos_or[v]\n",
    "\n",
    "    t = 0.30\n",
    "    label_x = x1 * (1 - t) + x2 * t\n",
    "    label_y = y1 * (1 - t) + y2 * t\n",
    "\n",
    "    # Small alternating offset for nearby labels\n",
    "    label_y += (-1) ** label_idx * 0.08\n",
    "\n",
    "    edge_score = G_or[u][v][\"weight\"]\n",
    "\n",
    "    ax.text(\n",
    "        label_x,\n",
    "        label_y,\n",
    "        f\"{edge_score:.2f}\",\n",
    "        fontsize=10,\n",
    "        fontweight=\"bold\",\n",
    "        color=\"#2b2b2b\",\n",
    "        ha=\"center\",\n",
    "        va=\"center\",\n",
    "        bbox={\n",
    "            \"boxstyle\": \"round,pad=0.25\",\n",
    "            \"facecolor\": \"white\",\n",
    "            \"edgecolor\": \"#cfcfcf\",\n",
    "            \"alpha\": 0.94,\n",
    "        },\n",
    "        zorder=10,\n",
    "    )\n",
    "\n",
    "\n",
    "legend_elements = [\n",
    "    Line2D(\n",
    "        [0],\n",
    "        [0],\n",
    "        marker=\"o\",\n",
    "        color=\"w\",\n",
    "        label=\"Target fraud node\",\n",
    "        markerfacecolor=node_color_map[\"target\"],\n",
    "        markeredgecolor=\"#1f1f1f\",\n",
    "        markersize=14,\n",
    "    ),\n",
    "    Line2D(\n",
    "        [0],\n",
    "        [0],\n",
    "        marker=\"o\",\n",
    "        color=\"w\",\n",
    "        label=\"Fraud node\",\n",
    "        markerfacecolor=node_color_map[\"fraud\"],\n",
    "        markeredgecolor=\"#1f1f1f\",\n",
    "        markersize=12,\n",
    "    ),\n",
    "    Line2D(\n",
    "        [0],\n",
    "        [0],\n",
    "        marker=\"o\",\n",
    "        color=\"w\",\n",
    "        label=\"Legitimate node\",\n",
    "        markerfacecolor=node_color_map[\"legitimate\"],\n",
    "        markeredgecolor=\"#1f1f1f\",\n",
    "        markersize=12,\n",
    "    ),\n",
    "    Line2D(\n",
    "        [0],\n",
    "        [0],\n",
    "        marker=\"o\",\n",
    "        color=\"w\",\n",
    "        label=\"Unknown-label node\",\n",
    "        markerfacecolor=node_color_map[\"unknown\"],\n",
    "        markeredgecolor=\"#1f1f1f\",\n",
    "        markersize=12,\n",
    "    ),\n",
    "    Line2D(\n",
    "        [0],\n",
    "        [0],\n",
    "        color=\"#5f5f5f\",\n",
    "        linewidth=3.5,\n",
    "        label=\"ORExplainer edge importance\",\n",
    "    ),\n",
    "]\n",
    "\n",
    "ax.legend(\n",
    "    handles=legend_elements,\n",
    "    loc=\"upper left\",\n",
    "    bbox_to_anchor=(1.01, 1.0),\n",
    "    frameon=True,\n",
    "    fontsize=9,\n",
    ")\n",
    "\n",
    "ax.set_title(\n",
    "    f\"ORExplainer-style Edge-based Explanation for Target Node {target_node_id}\",\n",
    "    fontsize=16,\n",
    "    fontweight=\"bold\",\n",
    "    pad=20,\n",
    ")\n",
    "\n",
    "ax.text(\n",
    "    0.01,\n",
    "    -0.04,\n",
    "    \"Edge scores are directly learned by the ORExplainer-style edge mask.\",\n",
    "    transform=ax.transAxes,\n",
    "    fontsize=10,\n",
    "    color=\"#333333\",\n",
    ")\n",
    "\n",
    "ax.set_xlim(-2.85, 4.5)\n",
    "ax.set_ylim(-3.2, 3.2)\n",
    "ax.axis(\"off\")\n",
    "\n",
    "plt.tight_layout(rect=[0, 0, 0.82, 1])\n",
    "plt.show()"
   ]
