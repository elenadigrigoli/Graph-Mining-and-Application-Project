    "top_k = 10\n",
    "\n",
    "# Flatten the learned node mask\n",
    "node_scores_caus = caus_mask.view(-1).detach()\n",
    "\n",
    "# Derive edge scores from source and target node importance\n",
    "edge_scores_caus = (\n",
    "    node_scores_caus[sub_edge_index.cpu()[0]] +\n",
    "    node_scores_caus[sub_edge_index.cpu()[1]]\n",
    ") / 2\n",
    "\n",
    "\n",
    "# Summarize derived edge scores\n",
    "caus_edge_score_summary = pd.DataFrame(\n",
    "    {\n",
    "        \"Property\": [\n",
    "            \"Score type\",\n",
    "            \"Edge scores shape\",\n",
    "            \"Minimum edge score\",\n",
    "            \"Maximum edge score\",\n",
    "            \"Mean edge score\",\n",
    "            \"Non-zero edge scores\",\n",
    "        ],\n",
    "        \"Value\": [\n",
    "            \"Derived from CausGNN-style node importance\",\n",
    "            tuple(edge_scores_caus.shape),\n",
    "            f\"{edge_scores_caus.min().item():.6f}\",\n",
    "            f\"{edge_scores_caus.max().item():.6f}\",\n",
    "            f\"{edge_scores_caus.mean().item():.6f}\",\n",
    "            int((edge_scores_caus > 0).sum().item()),\n",
    "        ],\n",
    "    }\n",
    ")\n",
    "\n",
    "display(caus_edge_score_summary)\n",
    "\n",
    "\n",
    "# Rank the most important nodes\n",
    "top_k_nodes_caus = min(top_k, node_scores_caus.numel())\n",
    "\n",
    "top_node_values_caus, top_node_indices_caus = torch.topk(\n",
    "    node_scores_caus,\n",
    "    k=top_k_nodes_caus,\n",
    ")\n",
    "\n",
    "top_caus_nodes = []\n",
    "\n",
    "for rank, local_idx in enumerate(top_node_indices_caus, start=1):\n",
    "    local_idx = int(local_idx.item())\n",
    "    original_node_id = int(subset[local_idx].item())\n",
    "    node_score = float(top_node_values_caus[rank - 1].item())\n",
    "    label_value = int(graph_data.y[original_node_id].item())\n",
    "\n",
    "    if label_value == 1:\n",
    "        label = \"Fraud\"\n",
    "    elif label_value == 0:\n",
    "        label = \"Legitimate\"\n",
    "    else:\n",
    "        label = f\"Unknown ({label_value})\"\n",
    "\n",
    "    top_caus_nodes.append(\n",
    "        {\n",
    "            \"Rank\": rank,\n",
    "            \"Local node index\": local_idx,\n",
    "            \"Original node ID\": original_node_id,\n",
    "            \"Node importance score\": round(node_score, 4),\n",
    "            \"Label\": label,\n",
    "            \"Is target node\": local_idx == target_sub_idx,\n",
    "        }\n",
    "    )\n",
    "\n",
    "top_caus_nodes_df = pd.DataFrame(top_caus_nodes)\n",
    "display(top_caus_nodes_df)\n",
    "\n",
    "\n",
    "# Rank the most important derived edges\n",
    "top_k_edges_caus = min(top_k, edge_scores_caus.numel())\n",
    "\n",
    "top_edge_values_caus, top_edge_indices_caus = torch.topk(\n",
    "    edge_scores_caus,\n",
    "    k=top_k_edges_caus,\n",
    ")\n",
    "\n",
    "top_caus_edges = []\n",
    "\n",
    "for rank, edge_idx in enumerate(top_edge_indices_caus, start=1):\n",
    "    edge_idx = int(edge_idx.item())\n",
    "\n",
    "    # Retrieve local edge endpoints\n",
    "    source_local = int(sub_edge_index[0, edge_idx].item())\n",
    "    target_local = int(sub_edge_index[1, edge_idx].item())\n",
    "\n",
    "    # Map local indices back to original graph IDs\n",
    "    source_original = int(subset[source_local].item())\n",
    "    target_original = int(subset[target_local].item())\n",
    "\n",
    "    edge_score = float(top_edge_values_caus[rank - 1].item())\n",
    "\n",
    "    top_caus_edges.append(\n",
    "        {\n",
    "            \"Rank\": rank,\n",
    "            \"Edge index\": edge_idx,\n",
    "            \"Source local index\": source_local,\n",
    "            \"Target local index\": target_local,\n",
    "            \"Source original ID\": source_original,\n",
    "            \"Target original ID\": target_original,\n",
    "            \"Derived edge score\": round(edge_score, 4),\n",
    "            \"Points to target node\": target_local == target_sub_idx,\n",
    "        }\n",
    "    )\n",
    "\n",
    "top_caus_edges_df = pd.DataFrame(top_caus_edges)\n",
    "display(top_caus_edges_df)"
   ]
  },
